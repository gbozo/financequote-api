# FinanceQuote API - Environment Variables Example
# Copy this to .env and fill in your API keys

# === API Authentication ===
# Comma-separated list of API keys that can access the service
# If not set, API will work without authentication
# Example: API_AUTH_KEYS=key1,key2,key3
API_AUTH_KEYS=

# === Stock Quote API Keys ===

# AlphaVantage - https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your_alphavantage_key

# TwelveData - https://twelvedata.com/pricing
TWELVEDATA_API_KEY=your_twelvedata_key

# FinanceAPI - https://financeapi.io/
FINANCEAPI_API_KEY=your_financeapi_key

# StockData - https://stockdata.org/
STOCKDATA_API_KEY=your_stockdata_key

# === Currency Rate API Keys ===

# Fixer.io - https://fixer.io/
FIXER_API_KEY=your_fixer_key

# OpenExchangeRates - https://openexchangerates.org/
OPENEXCHANGE_API_KEY=your_openexchange_key

# CurrencyFreaks - https://currencyfreaks.com/
CURRENCYFREAKS_API_KEY=your_currencyfreaks_key

# === API Configuration ===

APP_ENV=development
FQ_TIMEOUT=30
FQ_FAILOVER=1